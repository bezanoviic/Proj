<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<appSettings>
		<add key="StudentFilesPath" value="Data" />
	</appSettings>
	<system.serviceModel>
		<services>
			<service name="Service.StudentService">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4002" />
					</baseAddresses>
				</host>
				<endpoint
					address="StudentService"
					binding="netTcpBinding"
					contract="Common.IStudentService" />
			</service>
		</services>
	</system.serviceModel>
</configuration>